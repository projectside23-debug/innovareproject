# Neon Postgres connection string.
# Copy this from the Neon console:
# https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Secret used to sign Innovare auth sessions.
# Generate one with: openssl rand -base64 32
AUTH_SESSION_SECRET="replace-with-a-long-random-secret"

# Optional managed Neon Auth beta settings.
# If you later want to switch from the built-in credentials auth to managed Neon Auth,
# enable Neon Auth in the Neon console and fill these from Neon Auth settings.
NEON_AUTH_BASE_URL=""
NEON_AUTH_COOKIE_SECRET=""
